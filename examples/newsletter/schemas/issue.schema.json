{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "issue — one weekly newsletter",
  "description": "The rendered newsletter file is a projection of this record (tools/assemble_issue.py) — never hand-written (OVERVIEW rule 4). May only reference included articles (rule 3, enforced in validate.py and refused at assembly).",
  "x-kind": "issue",
  "type": "object",
  "required": ["id", "title", "week_start", "week_end", "created", "articles", "status"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^N-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 1 },
    "week_start": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "week_end": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "created": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "articles": {
      "type": "array",
      "items": { "type": "string", "pattern": "^A-[0-9]{3}$" },
      "description": "The included articles this issue carries, in run order."
    },
    "executive_summary": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
    "status": { "enum": ["draft", "final"] }
  }
}
