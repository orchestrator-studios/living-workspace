{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Search",
  "description": "A logged sweep — the provenance of coverage. Lives in data/searches/<id>.json.",
  "type": "object",
  "required": ["id", "date", "database", "query", "hits", "added"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^Q-[0-9]{2}$" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "database": { "type": "string", "minLength": 1 },
    "query": { "type": "string", "minLength": 1 },
    "hits": { "type": "number", "minimum": 0 },
    "added": { "type": "array", "items": { "type": "string", "pattern": "^S-[0-9]{3}$" } },
    "notes": { "type": "string" }
  }
}
