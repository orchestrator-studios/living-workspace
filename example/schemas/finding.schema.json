{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding",
  "description": "One extracted claim from one INCLUDED source. Lives in data/findings/<id>.json. Created only by tools/add_finding.py, which refuses sources that are not included — see skills/findings-and-citations.md.",
  "type": "object",
  "required": ["id", "source_id", "claim", "outcome", "direction", "evidence", "theme_id"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^F-[0-9]{3}$" },
    "source_id": { "type": "string", "pattern": "^S-[0-9]{3}$" },
    "claim": { "type": "string", "minLength": 1 },
    "outcome": { "type": "string", "enum": ["readmission", "mortality", "adherence", "cost"] },
    "direction": { "type": "string", "enum": ["reduction", "no_effect", "increase", "mixed"] },
    "evidence": { "type": "string", "minLength": 1 },
    "theme_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^T-[0-9]{2}$" }
      ]
    }
  }
}
