{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source",
  "description": "A paper under consideration. Lives in data/sources/<id>.json. Screening decisions record the criterion they were decided on — see skills/screening.md.",
  "type": "object",
  "required": ["id", "title", "authors", "year", "venue", "doi", "found_via", "screening"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^S-[0-9]{3}$" },
    "title": { "type": "string", "minLength": 1 },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "year": { "type": "number", "minimum": 1990, "maximum": 2030 },
    "venue": { "type": "string", "minLength": 1 },
    "doi": { "type": "string", "minLength": 1 },
    "found_via": { "type": "string", "pattern": "^(seeded|search:Q-[0-9]{2}|citation:S-[0-9]{3})$" },
    "screening": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["unscreened", "included", "excluded"] },
        "criterion": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
      }
    },
    "notes": { "type": "string" }
  }
}
