{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Invoice",
  "description": "An invoice drawing unbilled time for one client. Lives in data/invoices/<id>.json. Created only by tools/make_invoice.py — see skills/invoicing.md.",
  "type": "object",
  "required": ["id", "client_id", "date", "line_items", "total", "currency", "status"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^INV-[0-9]{4}-[0-9]{3}$" },
    "client_id": { "type": "string", "pattern": "^CL-[0-9]{3}$" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["time_entry_id", "project_id", "date", "hours", "rate", "amount"],
        "additionalProperties": false,
        "properties": {
          "time_entry_id": { "type": "string", "pattern": "^TE-[0-9]{4}$" },
          "project_id": { "type": "string", "pattern": "^PR-[0-9]{3}$" },
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "hours": { "type": "number", "exclusiveMinimum": 0 },
          "rate": { "type": "number", "exclusiveMinimum": 0 },
          "amount": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "total": { "type": "number", "exclusiveMinimum": 0 },
    "currency": { "type": "string", "enum": ["USD"] },
    "status": { "type": "string", "enum": ["draft", "sent", "paid"] }
  }
}
