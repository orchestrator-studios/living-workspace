{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "description": "An engagement for a client, billed hourly. Lives in data/projects/<id>.json",
  "type": "object",
  "required": ["id", "client_id", "name", "rate", "currency", "status", "start_date"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^PR-[0-9]{3}$" },
    "client_id": { "type": "string", "pattern": "^CL-[0-9]{3}$" },
    "name": { "type": "string", "minLength": 1 },
    "rate": { "type": "number", "exclusiveMinimum": 0 },
    "currency": { "type": "string", "enum": ["USD"] },
    "status": { "type": "string", "enum": ["active", "paused", "completed"] },
    "start_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "notes": { "type": "string" }
  }
}
