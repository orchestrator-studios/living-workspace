{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimeEntry",
  "description": "A block of billable work on a project. Lives in data/time/<id>.json. Once billed=true, the entry is frozen — see skills/invoicing.md.",
  "type": "object",
  "required": ["id", "project_id", "date", "hours", "description", "billed", "invoice_id"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^TE-[0-9]{4}$" },
    "project_id": { "type": "string", "pattern": "^PR-[0-9]{3}$" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "hours": { "type": "number", "multipleOf": 0.25, "minimum": 0.25, "maximum": 16 },
    "description": { "type": "string", "minLength": 1 },
    "billed": { "type": "boolean" },
    "invoice_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^INV-[0-9]{4}-[0-9]{3}$" }
      ]
    }
  }
}
