{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "protocol.schema.json",
  "title": "Review protocol",
  "description": "The definition of one systematic review: question, criteria, search strategy.",
  "type": "object",
  "required": ["slug", "title", "question", "inclusion_criteria", "exclusion_reasons", "searches"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "pico": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "population": { "type": "string" },
        "exposure": { "type": "string" },
        "comparator": { "type": "string" },
        "outcome": { "type": "string" }
      }
    },
    "inclusion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "exclusion_reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "searches": {
      "type": "array",
      "description": "Executed search runs; append-only log.",
      "items": {
        "type": "object",
        "required": ["database", "query", "date", "count"],
        "additionalProperties": false,
        "properties": {
          "database": { "type": "string" },
          "query": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "count": { "type": "integer", "minimum": 0 },
          "note": { "type": "string" }
        }
      }
    },
    "extraction_profile": {
      "type": "object",
      "description": "Declares the per-arm data fields extracted for this review. Topic-specific; makes the engine (schemas/tools) reusable across review subjects.",
      "required": ["fields", "summary_field"],
      "additionalProperties": false,
      "properties": {
        "arm_noun": { "type": "string", "description": "human name for one arm, e.g. 'gene arm', 'trial arm'" },
        "summary_field": { "type": "string", "description": "key of the categorical field the report groups and colours by" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["key", "label"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
              "label": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "in_table": { "type": "boolean", "description": "show as a column in generated tables (default true)" },
              "help": { "type": "string" },
              "categorical": {
                "type": "object",
                "required": ["values"],
                "additionalProperties": false,
                "properties": {
                  "values": {
                    "type": "object",
                    "minProperties": 1,
                    "additionalProperties": {
                      "type": "object",
                      "required": ["label", "tone"],
                      "additionalProperties": false,
                      "properties": {
                        "label": { "type": "string" },
                        "tone": { "type": "string", "enum": ["positive", "negative", "neutral", "warn", "accent"] }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
