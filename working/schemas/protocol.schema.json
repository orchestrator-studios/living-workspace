{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "protocol.schema.json",
  "title": "Review protocol",
  "description": "The definition of one systematic review: question, criteria, search strategy.",
  "type": "object",
  "required": ["slug", "title", "question", "inclusion_criteria", "exclusion_reasons", "searches"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "question": { "type": "string", "minLength": 1 },
    "pico": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "population": { "type": "string" },
        "exposure": { "type": "string" },
        "comparator": { "type": "string" },
        "outcome": { "type": "string" }
      }
    },
    "inclusion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "exclusion_reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "searches": {
      "type": "array",
      "description": "Executed search runs; append-only log.",
      "items": {
        "type": "object",
        "required": ["database", "query", "date", "count"],
        "additionalProperties": false,
        "properties": {
          "database": { "type": "string" },
          "query": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "count": { "type": "integer", "minimum": 0 },
          "note": { "type": "string" }
        }
      }
    }
  }
}
